---
// import MainLayout
import MainLayout from "../layout/MainLayout.astro"
// import data from data.js
import { data } from "../data/data.js";

// define the items to use from data.js
const items = data.glossaryItems;

// get all the categories
const allCategories = items.flatMap(item => item.categories);
// remove duplicates and turn in back into an array
const categories = [...new Set(allCategories)];

---

<MainLayout>
	<!-- dynamically add all links to the glossary-item pages -->
	<ul class="term-categories">
		 {categories?.map((category) => !category || category.trim() === "" ? null : (
				<li class={category}>
					<label>
					<input type="checkbox" />
					{category}
					</label>
				</li>
			)
		)}
	</ul>

	<ul class="term-list">
		{items?.map((item) => (
			<li class={item.categories.join(" ")}>
				<a href=`glossary-items/${item.slug}` class="hover-underline">{item.title}</a>
			</li>
		))}
	</ul>




	<script src="/js/index.js" is:inline></script>

	<script is:inline define:vars={{ categories }}>
		// Dynamically generate one highlight selector per category
		// first filter out empty categories
		const validCategories = (categories ?? []).filter(
			(category) => category && category.trim() !== ""
		);

		// if there are valid categories, return the highlighted style on selection
		if (validCategories.length > 0) {
			const style = document.createElement("style");
			style.textContent =
			validCategories
				.map(
				(category) =>
					`.term-categories:has(.${category} :checked) ~ .term-list .${category}`
				)
				.join(",\n") +
			` {
				opacity: 1;
				transition: var(--terms-transition-time);
				pointer-events: all;
			}`;
			document.head.appendChild(style);
		}
	</script>
</MainLayout>