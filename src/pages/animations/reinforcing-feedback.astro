---

<div class="word" id="word">
    <span>r</span>
    <span>e</span>
    <span>i</span>
    <span>n</span>
    <span>f</span>
    <span>o</span>
    <span>r</span>
    <span>c</span>
    <span>i</span>
    <span>n</span>
    <span>g</span>

    <span class="space">&nbsp;</span>

    <span>f</span>
    <span>e</span>
    <span>e</span>
    <span>d</span>
    <span>b</span>
    <span>a</span>
    <span>c</span>
    <span>k</span>
</div>

<script>
    const letters = [...document.querySelectorAll(".word span:not(.space)")];

    const state = letters.map(() => ({
        energy: 0,
        hoverInfluence: 0,
    }));

    let mouseX = -1000;
    let mouseY = -1000;

    let isMoving = false;
    let moveTimeout;

    let resetting = false;

    // starts white
    let darkMode = false;

    document.addEventListener("mousemove", (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;

        isMoving = true;

        clearTimeout(moveTimeout);

        moveTimeout = setTimeout(() => {
            isMoving = false;
        }, 60);
    });

    function resetSystem() {
        state.forEach((s) => {
            s.energy = 0;
            s.hoverInfluence = 0;
        });
    }

    function animate() {
        state.forEach((s) => {
            s.hoverInfluence = 0;
        });

        // --------------------
        // MOUSE INFLUENCE
        // --------------------

        letters.forEach((letter, i) => {
            const rect = letter.getBoundingClientRect();

            const cx = rect.left + rect.width / 2;
            const cy = rect.top + rect.height / 2;

            const dx = mouseX - cx;
            const dy = mouseY - cy;

            const dist = Math.sqrt(dx * dx + dy * dy);

            const radius = 200;

            if (dist < radius) {
                const influence = Math.pow(1 - dist / radius, 3);

                state[i].energy += influence * 0.9;

                state[i].hoverInfluence = influence;
            }
        });

        // --------------------
        // NEIGHBOUR SPREAD
        // --------------------

        if (isMoving) {
            state.forEach((s, i) => {
                const spread = s.hoverInfluence * 0.4;

                if (state[i - 1]) {
                    state[i - 1].energy += spread * 0.05;
                }

                if (state[i + 1]) {
                    state[i + 1].energy += spread * 0.05;
                }
            });
        }

        // --------------------
        // AVERAGE ENERGY
        // --------------------

        let totalEnergy = 0;

        state.forEach((s) => {
            totalEnergy += s.energy;
        });

        const averageEnergy = totalEnergy / state.length;

        // --------------------
        // LETTERS
        // --------------------

        state.forEach((s, i) => {
            const weight = Math.min(900, 100 + s.energy * 25);

            let scaleX = 1;
            let scaleY = 1;

            // --------------------------------
            // PHASE 1
            // Uniform growth
            // --------------------------------

            if (s.energy > 30) {
                const growth = 1 + Math.pow((s.energy - 30) / 35, 1.4);

                scaleX = growth;
                scaleY = growth;
            }

            scaleX = Math.min(scaleX, 4);
            scaleY = Math.min(scaleY, 4);

            // --------------------------------
            // PHASE 2
            // Vertical takeover
            // --------------------------------

            if (scaleY > 3.8) {
                const stretchProgress = (scaleY - 3.8) / 0.2;

                scaleY = 4 + stretchProgress * 20;
            }

            letters[i].style.fontVariationSettings =
                `"wght" ${Math.round(weight / 10) * 10}`;

            letters[i].style.transform = `scale(${scaleX},${scaleY})`;
        });

        // --------------------
        // COLLAPSE EVENT
        // --------------------

        if (averageEnergy > 110 && !resetting) {
            resetting = true;

            // invert world
            darkMode = !darkMode;

            if (darkMode) {
                document.body.style.background = "black";

                document.body.style.color = "white";
            } else {
                document.body.style.background = "white";

                document.body.style.color = "black";
            }

            // wait for inversion
            setTimeout(() => {
                resetSystem();

                resetting = false;
            }, 1200);
        }

        requestAnimationFrame(animate);
    }

    animate();
</script>
