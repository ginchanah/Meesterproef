---
import DetailLayout from "../../layout/DetailLayout.astro";
import Header from "../../components/Header.astro";
---

<DetailLayout title="Contact">
    <Header variant="two" title="About" />

    <main class="page">
        <section class="content-section">
            <div class="block block-header animate-on-scroll is-visible">
                <h2>contact</h2>
            </div>
            <div class="row row-full">
                <div class="block block-text-large block-text-full animate-on-scroll is-visible">
                    <p>
                        Feel free to get in touch regarding research,
                        collaborations, lectures, or other inquiries.
                    </p>
                    <p class="block-cite"><a href="mailto:m.ruyg@hva.nl">m.ruyg@hva.nl</a></p>
                    <p class="block-author">Marjolijn Ruyg <br> Amsterdam</p>
                </div>
            </div>
        </section>
    </main>
</DetailLayout>
