---
import SubPageLayout from "../../layout/SubPageLayout.astro";
import Header from "../../components/Header.astro";
---

<SubPageLayout title="Contact">
    <Header variant="two" title="Contact" />

    <main class="page full-height">
        <section class="content-section">
            <div class="block block-header animate-on-scroll is-visible">
                <h2>contact</h2>
            </div>
            <div class="row row-full">
                <div
                    class="block block-text-large block-text-full animate-on-scroll is-visible"
                >
                    <p>
                        Feel free to get in touch regarding research,
                        collaborations, lectures, or other inquiries.
                    </p>
                    <a href="mailto:m.ruyg@hva.nl" class="hover-underline button-small">Get in contact →</a>

                    <p class="block-author">Marjolijn Ruyg <br/> Amsterdam</p>
                </div>
                    <p class="block block-text-small animate-on-scroll is-visible">
                        <a href="mailto:m.ruyg@hva.nl">m.ruyg@hva.nl</a>
                    </p>
               
            </div>
        </section>
    </main>

    <script src="/js/index.js" is:inline></script>
</SubPageLayout>
