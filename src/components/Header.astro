---
// link to the header:
// src/components/Header.astro

// define two variants for the header
interface Props {
    variant?: "one" | "two";
    title?: String;
    slug?: String;
}

// define props to receive from other components
const { variant = "one", title, slug } = Astro.props;

// Dynamically import the animation file based on slug
const animations = import.meta.glob("../animations/*.astro", { eager: true });
const animationPath = `../animations/${slug}.astro`;
const AnimationComponent = (
    animations[animationPath] as { default: any } | undefined
)?.default;
---

<!-- here we define two different headers for the homepage and for the detail page -->
<header class={`header header-${variant}`}>
    <!-- this is the header for the homepage -->
    {
        variant === "one" && (
            <div class="header1-container">
                <h1 id="index-h1">
                    <span>(Inter)facing the Hybrid City</span>
                    <span>Glossary</span>
                </h1>
                <div class="header1-nav">
                    <a
                        href="/sub-pages/about"
                        class="hover-underline button-small"
                    >
                        ABOUT
                    </a>
                    <a
                        href="/sub-pages/contact"
                        class="hover-underline button-small"
                    >
                        CONTACT
                    </a>
                </div>
            </div>
        )
    }

    <!-- this is the header for the glossary item page -->
    {
        variant === "two" && (
            <>
                <nav class="header2-nav">
                    <div>
                        <a class="button-big hover-underline" href="/">
                            <span aria-hidden="true">←</span> Glossary
                        </a>
                        <p>(Inter)facing the Hybrid City</p>
                    </div>
                    <div class="header2-links">
                        <a
                            href="/sub-pages/about"
                            class="hover-underline button-small"
                        >
                            ABOUT
                        </a>
                        <a
                            href="/sub-pages/contact"
                            class="hover-underline button-small"
                        >
                            CONTACT
                        </a>
                    </div>
                </nav>

                {AnimationComponent ? (
                    <div class="animation-section">
                        <h1 class="visually-hidden">{title}</h1>
                        <div aria-hidden="true">
                            <AnimationComponent />
                        </div>
                    </div>
                ) : null}
            </>
        )
    }
</header>
<style>
    .header1-container {
        position: relative;
    }
    .header1-nav {
        position: absolute;
        top: 0;
        right: 0;
        display: flex;
        gap: 1em;
    }

    @media (max-width: 800px) {
        .header1-nav {
            position: relative;
            justify-content: flex-start;
            width: auto;
            border-top: solid 2px var(--color-text);
            border-bottom: solid 2px var(--color-text);
            padding: 0.5em 0;
            margin-bottom: 2rem;
            gap: 2em;
        }
    }

    .header2-nav {
        font-family: var(--inter-regular);
        margin: var(--body-padding);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .header2-nav a {
        width: auto;
        /* text-decoration: none; */
        text-wrap: nowrap;
    }
    .header2-nav p {
        height: var(--font-button-big-size);
        padding: 0 1em;
        margin-right: 1em;
        display: flex;
        align-items: center;
        &::before {
            content: "";
            display: inline-block;
            background-color: var(--color-text);
            height: 90%;
            margin-right: 1em;
            border-right: solid 2px var(--color-text);
        }
    }
    .header2-nav div:nth-child(1) {
        display: flex;
        align-items: center;
    }
    .header2-links {
        display: flex;
        gap: 1em;
    }
    @media (max-width: 800px) {
        .header2-nav {
            flex-direction: column;
            align-items: flex-start;
            gap: 1em;
        }
        .header2-links {
            width: 100%;
            justify-content: flex-start;
            border-top: solid 2px var(--color-text);
            border-bottom: solid 2px var(--color-text);
            padding: 0.5em 0;
            margin-bottom: 2rem;
            gap: 2em;
        }
        @media (max-width: 600px) {
            p {
                font-size: 0.75em;
            }
        }
    }
</style>
