---
// link to the footer:
// src/components/Footer.astro
import { data } from "../data/data.js";

// define props to receive from other components
const { variant = "home", title, item } = Astro.props;

let prevItem = null;
let nextItem = null;

if (variant === "detail" && item) {
    const items = data.glossaryItems;
    // use the first category to find siblings
    const category = item.categories && item.categories.length > 0 ? item.categories[0] : null;
    
    if (category) {
        const categoryItems = items.filter(i => i.categories && i.categories.includes(category));
        const currentIndex = categoryItems.findIndex(i => i.slug === item.slug);
        
        if (currentIndex !== -1 && categoryItems.length > 1) {
            const prevIndex = (currentIndex - 1 + categoryItems.length) % categoryItems.length;
            const nextIndex = (currentIndex + 1) % categoryItems.length;
            
            prevItem = categoryItems[prevIndex];
            nextItem = categoryItems[nextIndex];
        }
    }
}
---



<!-- ===================================== -->
<!-- MARK: Footer                          -->
<!-- ===================================== -->
<footer class={`footer footer-${variant}`}>
    <!-- ---------- Homepage Footer ---------- -->
    {variant === "index" && (

        <div>
            <!-- Banner -->
            <div class="banner-container">
                <div class="banner-content" id="bannerContent" data-word="glossary">
                <!-- Populated by index.js -->
                </div>
            </div>
            <p class="footer-copyright">&copy; 2026 MARJOLIJN RUYG, WEBSITE BUILT BY TEAM FONT-END.</p>
        </div>

    )}

    <!-- ---------- Subpage Footer ---------- -->
    {variant === "subpage" && (

        <div>
            <!-- Banner -->
            <div class="banner-container">
                <div class="banner-content" id="bannerContent">
                <!-- Populated by index.js -->
                </div>
            </div>
            <p class="footer-copyright">&copy; 2026 MARJOLIJN RUYG, WEBSITE BUILT BY TEAM FONT-END.</p>
        </div>

    )}
    
    <!-- ---------- Detail Page Footer ---------- -->
    {variant === "detail" && (

        <!-- Navigation between glossary items -->
        <div>
            <nav class="footer-nav">
                {prevItem && (
                     <a href={`/glossary-items/${prevItem.slug}`} class="hover-underline">
                         &larr; {prevItem.title}
                    </a>
                )}
                <a href="/" class="hover-underline">BACK TO GLOSSARY</a>
                {nextItem && (
                    <a href={`/glossary-items/${nextItem.slug}`} class="hover-underline">{nextItem.title} &rarr;</a>
                )}
            </nav>
                <div class="banner-container">
                    <div class="banner-content" id="bannerContent">
                    <!-- Populated by index.js -->
                    </div>
                </div>
            <p class="footer-copyright">&copy; 2026 MARJOLIJN RUYG, WEBSITE BUILT BY TEAM FONT-END.</p>
        </div>

    )}
</footer>
